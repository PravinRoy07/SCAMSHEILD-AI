          //   HTML CODE // 

<!DOCTYPE html>
<html lang="en">

<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>ScamShield AI</title>

<link rel="stylesheet" href="style.css">
</head>

<body>

<div class="container">

<h1>🛡 ScamShield AI</h1>

<textarea
id="userInput"
placeholder="Paste suspicious message, UPI ID, link etc..."
></textarea>

<button onclick="scanNow()">
Scan Now
</button>

<button onclick="downloadReport()">
📄 Download Report
</button>

<div class="result">

<h2 id="riskScore">
Risk Score: 0%
</h2>

<p id="message">
Waiting for scan...
</p>

</div>

<div class="history">

<h2>Recent Scans</h2>

<table>

<thead>
<tr>
<th>Type</th>
<th>Input</th>
<th>Risk</th>
</tr>
</thead>

<tbody id="historyTable">
</tbody>

</table>

</div>

<div class="tips">

<h2>Cyber Safety Tips</h2>

<p id="tip"></p>

</div>

<div class="assistant">

<h2>AI Security Assistant</h2>

<input
id="question"
placeholder="Ask something..."
>

<button onclick="askAI()">
Ask AI
</button>

<p id="answer"></p>

</div>

</div>

<script src="script.js"></script>

</body>
</html>  
