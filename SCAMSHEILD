      // JAVASCRIPT CODE // 

function scanNow(){

const input =
document
.getElementById("userInput")
.value
.toLowerCase();

let risk = 10;
let msg = "Looks Safe";

if(
input.includes("otp") ||
input.includes("password")
){
risk = 85;
msg = "High Risk Scam Detected";
}

document.getElementById(
"riskScore"
).innerText =
"Risk Score: " + risk + "%";

document.getElementById(
"message"
).innerText =
msg;

addHistory(
"Scan",
input,
risk + "%"
);

}

function addHistory(
type,
input,
risk
){

const row = `
<tr>
<td>${type}</td>
<td>${input.substring(0,30)}</td>
<td>${risk}</td>
</tr>
`;

document
.getElementById("historyTable")
.innerHTML += row;

}

function downloadReport(){

const score =
document
.getElementById(
"riskScore"
)
.innerText;

const message =
document
.getElementById(
"message"
)
.innerText;

const content = `
SCAMSHIELD AI REPORT

${score}

${message}

Generated:
${new Date()}
`;

const blob =
new Blob(
[content],
{
type:"text/plain"
}
);

const a =
document.createElement("a");

a.href =
URL.createObjectURL(blob);

a.download =
"ScamShieldReport.txt";

a.click();

}

const tips = [

"Never share OTP with anyone",

"Verify UPI ID before payment",

"Do not click unknown links",

"Bank never asks for password",

"Enable two-factor authentication"

];

let index = 0;

setInterval(()=>{

document
.getElementById("tip")
.innerText =
tips[index];

index++;

if(index >= tips.length){
index = 0;
}

},3000);

function askAI(){

const q =
document
.getElementById(
"question"
)
.value
.toLowerCase();

let answer =
"Please be cautious online.";

if(q.includes("otp")){
answer =
"Never share OTP with anyone.";
}

if(q.includes("upi")){
answer =
"Verify receiver details before payment.";
}

if(q.includes("link")){
answer =
"Avoid clicking unknown links.";
}

document
.getElementById(
"answer"
)
.innerText =
answer;

}
